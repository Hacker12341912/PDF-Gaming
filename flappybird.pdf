3 0 obj
<</AA
  <</O
  <</JS
  (
try {
  

const PAGE_WIDTH = 612;
const PAGE_HEIGHT = 792;

const GRAVITY = 12;

const BIRD_WIDTH = 64;
const BIRD_HEIGHT = 64;

const PIPE_WIDTH = 128;
const PIPE_HEIGHT = 512;
const PIPE_GAP = 184;

var score = 0;

var x = PAGE_WIDTH / 3;
var y = PAGE_HEIGHT / 2;

var isFlapping = false;
var flapPos = 0;
var timeElapsedFlap = 0;
const flapMagnitude = 90;
const flapSpeed = 5;
const terminalVel = 18;

var pipeX = 611;
var pipeY = PAGE_HEIGHT / 2;
var pipe2X = 611;
var pipe2Y = PAGE_HEIGHT / 2;

var pipeYOffset = 2;
var pipe2YOffset = 2;
var pipe2Move = false;
const pipeSpeed = 6;

var inArea = false;
const hitBoxMargin = -8;

var start = false;
var lose = false;
var revealed = false;

var cover = this.getField\("cover"\);

var updateLoop;

var delta;
var curTime;
var prevTime;

function init\(\) {
    if \(global.initialized\) return;
    global.initialized = true;

    reset\(\);
}

function reset\(\) {
    score = 0;

    x = PAGE_WIDTH / 3;
    y = PAGE_HEIGHT / 2;

    isFlapping = false;

    pipeX = 611;
    pipeY = PAGE_HEIGHT / 2;
    pipe2X = 611;
    pipe2Y = PAGE_HEIGHT / 2;
    pipeYOffset = 2;
    pipe2YOffset = 2;
    pipe2Move = false;

    inArea = false;

    start = false;
    lose = false;
    revealed = false;
    cover.display = display.visible;

    prevTime = Date.now\(\);

    if \(updateLoop\) app.clearTimeOut\(updateLoop\);

    getBirds\(\);
    getPipes\(\);

    wrappedDraw\(\);
}

function update\(\) {
    if \(!start\) return;

    curTime = Date.now\(\);
    delta = \(curTime - prevTime\) / 20;
    prevTime = curTime;

    if \(y <= -terminalVel\) {
        app.alert\("GAME OVER! You scored: " + score\);
        reset\(\);
        return;
    }

    if \(!lose\) {
        if \(pipeX > -PIPE_WIDTH\) {
            pipeX -= pipeSpeed * delta;
        }
        else {
            pipeX = 611;
            pipeYOffset = Math.floor\(\(Math.random\(\) * 4\)\);
        }

        if \(pipeX <= PAGE_WIDTH / 2 - PIPE_WIDTH / 2\) {
            pipe2Move = true;
        }

        if \(pipe2Move\) {
            if \(pipe2X > -PIPE_WIDTH\) {
                pipe2X -= pipeSpeed * delta;
            }
            else {
                pipe2X = 611;
                pipe2YOffset = Math.floor\(\(Math.random\(\) * 4\)\);
            }
        }
    }

    physics\(\);
    wrappedDraw\(\);
}

function physics\(\) {
    if \(!start\) return;

    if \(isFlapping\) {
        timeElapsedFlap += delta;
        var t = timeElapsedFlap / 10;
        var newY = flapPos + \(flapMagnitude * t\) - \(\(flapSpeed * t\) ** 2\);
        y = \(y - newY\) / delta < terminalVel ? newY : y - terminalVel;
    }

    if \(withinPipeX\(\(Math.abs\(pipeX - PAGE_WIDTH / 2\) <= Math.abs\(pipe2X - PAGE_WIDTH / 2\)\) ? pipeX : pipe2X\)\) {
        if \(withinPipeY\(Math.abs\(pipeX - PAGE_WIDTH / 2\) <= Math.abs\(pipe2X - PAGE_WIDTH / 2\) ? [pipeY, pipeYOffset] : [pipe2Y, pipe2YOffset]\)\) {
            lose = true;
            return;
        }
        else if\(!inArea\) {
            inArea = true;
            score += 1;
        }
    }
    else {
        inArea = false;
    }
}

function flap\(\) {
    if \(!revealed\) {
        revealed = true;
        cover.display = display.hidden;
        return;
    }

    if \(y >= 792 || lose\) return;
    flapPos = y;
    if \(!start\) {
        start = true;
        prevTime = Date.now\(\);
        if \(updateLoop\) app.clearTimeOut\(updateLoop\);
        updateLoop = app.setInterval\("update\(\)", 10\);
    }

    isFlapping = true;
    timeElapsedFlap = 0;
}

function withinPipeX\(px\) {
    return \(\(x + BIRD_WIDTH\) > \(px - hitBoxMargin\) && x < \(px + PIPE_WIDTH + hitBoxMargin\)\);
}

function withinPipeY\(py\) {
    return \(\(y + BIRD_HEIGHT\) > \(py[0] + PIPE_GAP / 2 + \(py[1] * 100 - 200\) - hitBoxMargin\) || y < \(py[0] - PIPE_GAP / 2 + \(py[1] * 100 - 200\) + hitBoxMargin\)\);
}

function draw\(\) {
    drawBird\(\);
    drawPipe\(\);
    drawScore\(\);
}

var birds = [];
var visibleBird = 99;
function getBirds\(\) {
    for \(let i=0; i<192; i++\) {
        birds[i] = this.getField\("berd" + \(i * 4\).toString\(\)\);
        birds[i].display = display.hidden;
    }
}

function drawBird\(\) {
    yRounded = Math.round\(Math.max\(Math.min\(y, 764\), 0\) / 4, 0\)
    birds[visibleBird].display = display.hidden;
    birds[yRounded].display = display.visible;
    visibleBird = yRounded;
}

var pipeTops = [[], [], [], [], []];
var pipeBottoms = [[], [], [], [], []];
function getPipes\(\) {
    for \(let y=0; y<5; y++\) {
        for \(let i=0; i<83; i++\) {
            pipeTops[y][i] = this.getField\("pipeTop" + \(y * 100 - 200\).toString\(\) + \(i * 9 - 127\).toString\(\)\);
            pipeTops[y][i].display = display.hidden;
            pipeBottoms[y][i] = this.getField\("pipeBottom" + \(y * 100 - 200\).toString\(\) + \(i * 9 - 127\).toString\(\)\);
            pipeBottoms[y][i].display = display.hidden;
        }
    }
}

var visiblePipe1 = [];
var visiblePipe2 = [];
function drawPipe\(\) {
    var xIndex1 = Math.max\(Math.round\(pipeX / 9, 0\) + 14, 0\);
    if \(visiblePipe1.length\) {
        pipeTops[visiblePipe1[0]][visiblePipe1[1]].display = display.hidden;
        pipeBottoms[visiblePipe1[0]][visiblePipe1[1]].display = display.hidden;
    }
    pipeTops[pipeYOffset][xIndex1].display = display.visible;
    pipeBottoms[pipeYOffset][xIndex1].display = display.visible;
    visiblePipe1 = [pipeYOffset, xIndex1];

    var xIndex2 = Math.max\(Math.round\(pipe2X / 9, 0\) + 14, 0\);
    if \(visiblePipe2.length\) {
        pipeTops[visiblePipe2[0]][visiblePipe2[1]].display = display.hidden;
        pipeBottoms[visiblePipe2[0]][visiblePipe2[1]].display = display.hidden;
    }
    pipeTops[pipe2YOffset][xIndex2].display = display.visible;
    pipeBottoms[pipe2YOffset][xIndex2].display = display.visible;
    visiblePipe2 = [pipe2YOffset, xIndex2];
}

var scoreText = this.getField\("score"\)
function drawScore\(\) {
    scoreText.value = start ? \("SCORE: " + score\) : \("Click anywhere to start!"\);
}

var whole = this.getField\('whole'\);
function wrappedDraw\(\) {
  try {
    whole.display = display.visible;
    draw\(\);
    whole.display = display.hidden;

  } catch \(e\) {
    app.alert\(e.toString\(\)\);
  }
}

init\(\);


} catch \(e\) {
  app.alert\(e.message\);
}
    )
